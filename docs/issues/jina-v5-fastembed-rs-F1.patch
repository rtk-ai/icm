             additional_files: vec!["onnx/model.onnx_data".to_string()],
             output_key: Some(crate::OutputKey::ByName("sentence_embedding")),
         },
         ModelInfo {
diff --git a/src/text_embedding/impl.rs b/src/text_embedding/impl.rs
