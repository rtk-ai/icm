     /// Quantized snowflake/snowflake-arctic-embed-s
     SnowflakeArcticEmbedSQ,
@@ -402,20 +410,31 @@ fn init_models_map() -> HashMap<EmbeddingModel, ModelInfo<EmbeddingModel>> {
         },
