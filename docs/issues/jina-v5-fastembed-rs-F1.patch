+            model_code: String::from("jinaai/jina-embeddings-v5-text-nano-retrieval"),
+            model_file: String::from("onnx/model.onnx"),
+            additional_files: Vec::new(),
+            output_key: None,
+        },
         ModelInfo {
             model: EmbeddingModel::EmbeddingGemma300M,
