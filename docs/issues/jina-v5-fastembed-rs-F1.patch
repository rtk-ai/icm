             EmbeddingModel::SnowflakeArcticEmbedXSQ => Some(Pooling::Cls),
             EmbeddingModel::SnowflakeArcticEmbedS => Some(Pooling::Cls),
             EmbeddingModel::SnowflakeArcticEmbedSQ => Some(Pooling::Cls),
